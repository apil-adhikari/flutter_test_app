      "link": null,
      "locked": false,
      "text": "final post = Post.fromJson(jsonDecode(response.body));\n\n// Now you get:\nprint(post.title);        // ✅ Autocomplete works!\nprint(post.userId);       // ✅ Type is guaranteed: int\n// post.titel;            // ❌ Compile-time error! Typo caught early.",
      "fontSize": 15.199999999999985,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "final post = Post.fromJson(jsonDecode(response.body));\n\n// Now you get:\nprint(post.title);        // ✅ Autocomplete works!\nprint(post.userId);       // ✅ Type is guaranteed: int\n// post.titel;            // ❌ Compile-time error! Typo caught early.",
      "autoResize": true,
      "lineHeight": 1.25
