      "updated": 1772198074945,
      "link": null,
      "locked": false,
      "text": "final response = await http.get(...);\nfinal data = jsonDecode(response.body); // This is a Map<String, dynamic>\n\n// Accessing data feels unsafe and messy:\nprint(data['title']); // What if 'title' is null? What if it's misspelled?\nprint(data['titel']); // Typo! No error until runtime 😱",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "final response = await http.get(...);\nfinal data = jsonDecode(response.body); // This is a Map<String, dynamic>\n\n// Accessing data feels unsafe and messy:\nprint(data['title']); // What if 'title' is null? What if it's misspelled?\nprint(data['titel']); // Typo! No error until runtime 😱",
      "autoResize": true,
      "lineHeight": 1.25
    },
